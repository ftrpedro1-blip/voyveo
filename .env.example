# Public URL
NEXT_PUBLIC_SITE_URL=https://voyveo.cassiahouseart.com

# Free map layer. Keep this OpenStreetMap-compatible and do not add paid map tokens.
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap

# Optional future persistence on Supabase Free.
# Leave empty until the admin needs durable production edits.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Safety: file DB writes are disabled on Vercel unless explicitly overridden.
# Keep false in production; use Supabase Free for persistent admin writes.
ALLOW_FILE_DB_WRITES=false
